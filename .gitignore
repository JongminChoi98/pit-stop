# pit-stop / .gitignore

# ────────── Flutter / Dart ──────────
.dart_tool/
.flutter-plugins
.flutter-plugins-dependencies
.packages
.pub-cache/
.pub/
build/

# pubspec.lock 은 앱 프로젝트에서 커밋합니다 (라이브러리만 ignore).
# 따라서 .gitignore에 포함하지 않음.

# ────────── IDE / Editor ──────────
.idea/
*.iml
*.ipr
*.iws
.vscode/
*.swp
*.swo

# ────────── Android ──────────
**/android/.gradle/
**/android/captures/
**/android/gradlew
**/android/gradlew.bat
**/android/local.properties
**/android/**/GeneratedPluginRegistrant.java
**/android/key.properties

# 서명 키 (절대 커밋 금지)
*.jks
*.keystore
*.p12

# ────────── iOS / macOS (사용 안 해도 안전상 포함) ──────────
**/ios/Flutter/.last_build_id
**/ios/Pods/
**/ios/.symlinks/
**/ios/Flutter/flutter_export_environment.sh
**/ios/Runner/GeneratedPluginRegistrant.*

# ────────── 테스트 / 커버리지 ──────────
coverage/
test/.test_coverage.dart

# ────────── Flutter Version Manager ──────────
.fvm/

# ────────── 시스템 / OS ──────────
.DS_Store
Thumbs.db
*.log

# ────────── 환경 변수 / 비밀 ──────────
.env
.env.*
!.env.example

# ────────── 임시 / 백업 ──────────
*.tmp
*.bak
*~